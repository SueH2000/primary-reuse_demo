# Public demo defaults
PUBLIC_DEMO_MODE=true
USE_OLLAMA=false

# Supabase feedback staging. Put real values in Render dashboard, not in GitHub.
USE_SUPABASE_FEEDBACK=true
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_FEEDBACK_TABLE=rag_feedback

# Optional local paths. Public mode falls back to data/demo_* files if private files are absent.
CLASSIFIER_LABELED_CSV=
CLASSIFIER_JSONL=
CLASSIFIER_FEEDBACK_STORE=runtime_state/demo_feedback.csv

# LLM guardrail: baseline rows with this confidence or higher are advisory-only for LLM.
CLASSIFIER_LLM_OVERRIDE_LOCK_THRESHOLD=0.85
# Either CLASSIFIER_OLLAMA_MODEL or OLLAMA_MODEL is accepted.
# CLASSIFIER_OLLAMA_MODEL=llama3:latest
# OLLAMA_MODEL=llama3:latest
